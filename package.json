{
  "name": "@ramp-sh/cli",
  "version": "0.1.0",
  "description": "Ramp CLI",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramp-sh/cli.git"
  },
  "homepage": "https://github.com/ramp-sh/cli",
  "bugs": {
    "url": "https://github.com/ramp-sh/cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ramp": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "pretest": "pnpm build",
    "test": "node --test tests/**/*.test.mjs",
    "sync-schema": "node scripts/sync-schema.mjs",
    "build": "tsup",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write --linter-enabled=false --assist-enabled=false .",
    "check:ci": "biome ci --linter-enabled=false --assist-enabled=false .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm check:ci && pnpm typecheck && pnpm test",
    "hooks:install": "node scripts/install-hooks.mjs",
    "prepare": "node scripts/install-hooks.mjs",
    "prepublishOnly": "pnpm run check:ci && pnpm run typecheck && pnpm run test"
  },
  "keywords": [
    "ramp",
    "cli",
    "deploy",
    "devops"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^14.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^24.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
