{
    "name": "@ramp-sh/cli",
    "version": "0.1.0",
    "description": "Ramp CLI",
    "type": "module",
    "packageManager": "pnpm@9.12.3",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mafrasil/ramp.git",
        "directory": "packages/cli"
    },
    "homepage": "https://github.com/mafrasil/ramp/tree/main/packages/cli",
    "bugs": {
        "url": "https://github.com/mafrasil/ramp/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "ramp": "./dist/bin.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "test": "node --test tests/**/*.test.mjs",
        "sync-schema": "node scripts/sync-schema.mjs",
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
    },
    "keywords": [
        "ramp",
        "cli",
        "deploy"
    ],
    "license": "UNLICENSED",
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "ajv": "^8.17.1",
        "commander": "^14.0.2",
        "yaml": "^2.8.1"
    },
    "devDependencies": {
        "@types/node": "^24.4.0",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2"
    }
}
